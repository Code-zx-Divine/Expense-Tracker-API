# ============================================
# EXPENSE TRACKER API - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# Server Configuration
NODE_ENV=production|development|test
PORT=3000

# MongoDB Atlas Connection String (REQUIRED)
# Get this from: MongoDB Atlas → Connect → Connect your application
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster0.XXXXX.mongodb.net/expenseDB?retryWrites=true&w=majority

# CORS Configuration (use * for development, specific URL for production)
# Examples:
#   Development: http://localhost:3000,http://localhost:5173
#   Production: https://yourfrontend.com
CORS_ORIGIN=http://localhost:3000

# Rate Limiting (requests per window in ms)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Request Timeout (milliseconds)
REQUEST_TIMEOUT=30000

# Logging Level (error|warn|info|debug|verbose)
LOG_LEVEL=info

# RapidAPI Configuration
# Set to 'true' to enable API key authentication via X-RapidAPI-Key header
RAPIDAPI_ENABLED=false

# Admin secret for managing API keys (CHANGE THIS IN PRODUCTION!)
# Used for /admin/* endpoints via X-Admin-Secret header
ADMIN_SECRET=change-this-to-strong-random-string

# Optional: Email notification for new API key requests (not implemented)
# NOTIFICATION_EMAIL=you@example.com
