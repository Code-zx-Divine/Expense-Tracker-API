# ============================================
# MongoDB Atlas Connection
# Get this from: cloud.mongodb.com → Connect → Drivers
# Example: mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority
# ============================================
MONGO_URI=your_mongodb_connection_string_here

# ============================================
# Admin Security (REQUIRED - no default)
# This protects /admin/* routes. Use a strong random secret.
# Generate: openssl rand -base64 32
# ============================================
ADMIN_SECRET=change-this-to-a-strong-random-secret

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3000

# CORS_ORIGIN: In production, set to your frontend URL (e.g., https://yourapp.com)
# Use * for development only (allows any origin)
CORS_ORIGIN=http://localhost:3000

# ============================================
# Rate Limiting (IP-based, applies to non-RapidAPI traffic)
# Window in milliseconds (default: 15 minutes)
# Max requests per window (default: 100)
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Request Timeout (milliseconds)
# ============================================
REQUEST_TIMEOUT=30000

# ============================================
# Logging
# Options: error, warn, info, debug
# ============================================
LOG_LEVEL=info

# ============================================
# RapidAPI Integration (Optional)
# If you're hosting this API on RapidAPI, set your upgrade URL here
# ============================================
RAPIDAPI_UPGRADE_URL=https://rapidapi.com/yourusername/expense-tracker-api

# ============================================
# Redis (Optional - for scalable rate limiting)
# If you add Redis for rate limiting across multiple instances:
# REDIS_URL=redis://username:password@hostname:port
# ============================================
# REDIS_URL=
